# ─────────────────────────────────────────
# JP Recruit Extractor - 环境变量配置
# ─────────────────────────────────────────

# LLM API Keys（至少设置一个）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LLM Settings
EXTRACTOR_LLM_PROVIDER=anthropic
EXTRACTOR_LLM_MODEL=claude-sonnet-4-20250514

# Extraction Settings
EXTRACTOR_DEFAULT_MODE=auto
EXTRACTOR_RULE_CONFIDENCE_THRESHOLD_HIGH=0.9
EXTRACTOR_RULE_CONFIDENCE_THRESHOLD_MEDIUM=0.7

# Paths
EXTRACTOR_RULE_DB_PATH=data/rules/rules.db
EXTRACTOR_CACHE_DIR=data/cache

# Processing
EXTRACTOR_MAX_WORKERS=4
EXTRACTOR_OCR_LANGUAGE=jap

# Logging
EXTRACTOR_LOG_LEVEL=INFO

# API Server
EXTRACTOR_API_HOST=0.0.0.0
EXTRACTOR_API_PORT=8000
EXTRACTOR_API_KEY=
